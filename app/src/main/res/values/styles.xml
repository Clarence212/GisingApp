<resources>
    <style name="DayCircle">
        <item name="android:layout_width">32dp</item>
        <item name="android:layout_height">32dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12sp</item>
        <item name="android:layout_marginEnd">4dp</item>
    </style>

    <style name="DayCircle.Selected" parent="DayCircle">
        <item name="android:background">@drawable/bg_day_squircle_selected</item>
        <item name="android:textColor">#FFFFFF</item>
    </style>

    <style name="DayCircle.Unselected" parent="DayCircle">
        <item name="android:background">@drawable/bg_day_squircle_unselected</item>
        <item name="android:textColor">#555555</item>
    </style>
</resources>