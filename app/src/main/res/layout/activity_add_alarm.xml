<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE">

    <!-- Header -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="100dp"
        android:background="#4364F7"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_back"
        android:layout_marginStart="20dp"
        android:padding="10dp"
        android:scaleType="centerInside"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintTop_toTopOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Alarm"
        android:textSize="22sp"
        android:fontFamily="sans-serif-black"
        android:textColor="#FFFFFF"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <!-- Content Scroll -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        app:layout_constraintBottom_toTopOf="@id/saveAlarmButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Time Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textColor="#888888"
                android:fontFamily="sans-serif-medium"
                android:textSize="15sp"/>

            <!-- Time Input Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginTop="12dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center">

                    <!-- Hour Adjust -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageButton
                            android:id="@+id/btnHourUp"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_back"
                            android:rotation="90"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#4364F7"/>
                        <TextView
                            android:id="@+id/tvHour"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="07"
                            android:textSize="32sp"
                            android:textColor="#333333"
                            android:fontFamily="sans-serif-black"/>
                        <ImageButton
                            android:id="@+id/btnHourDown"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_back"
                            android:rotation="270"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#4364F7"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=":"
                        android:textSize="32sp"
                        android:textColor="#333333"
                        android:layout_marginHorizontal="8dp"
                        android:fontFamily="sans-serif-black"/>

                    <!-- Minute Adjust -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">
                        <ImageButton
                            android:id="@+id/btnMinUp"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_back"
                            android:rotation="90"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#4364F7"/>
                        <TextView
                            android:id="@+id/tvMinute"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00"
                            android:textSize="32sp"
                            android:textColor="#333333"
                            android:fontFamily="sans-serif-black"/>
                        <ImageButton
                            android:id="@+id/btnMinDown"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_back"
                            android:rotation="270"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            app:tint="#4364F7"/>
                    </LinearLayout>

                    <!-- AM/PM Selector -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvAm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AM"
                            android:textSize="18sp"
                            android:textColor="#4364F7"
                            android:fontFamily="sans-serif-black"
                            android:padding="4dp"
                            android:clickable="true"
                            android:focusable="true"/>
                        <TextView
                            android:id="@+id/tvPm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PM"
                            android:textSize="18sp"
                            android:textColor="#CCCCCC"
                            android:fontFamily="sans-serif-black"
                            android:padding="4dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

                    <ImageButton
                        android:id="@+id/btnTimePicker"
                        android:layout_width="45dp"
                        android:layout_height="45dp"
                        android:src="@drawable/ic_back"
                        android:rotation="180"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="#CCCCCC"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Repeat Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repeat"
                android:textColor="#888888"
                android:fontFamily="sans-serif-medium"
                android:textSize="15sp"
                android:layout_marginTop="32dp"/>

            <!-- Repeat Days -->
            <LinearLayout
                android:id="@+id/daysContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_horizontal"
                android:layout_marginTop="12dp">

                <TextView android:id="@+id/daySun" style="@style/AlarmDayCircle" android:text="S" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
                <TextView android:id="@+id/dayMon" style="@style/AlarmDayCircle" android:text="M" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
                <TextView android:id="@+id/dayTue" style="@style/AlarmDayCircle" android:text="T" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
                <TextView android:id="@+id/dayWed" style="@style/AlarmDayCircle" android:text="W" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
                <TextView android:id="@+id/dayThu" style="@style/AlarmDayCircle" android:text="T" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
                <TextView android:id="@+id/dayFri" style="@style/AlarmDayCircle" android:text="F" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
                <TextView android:id="@+id/daySat" style="@style/AlarmDayCircle" android:text="S" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginHorizontal="4dp"/>
            </LinearLayout>

            <!-- Challenge Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Challenge Type"
                android:textColor="#888888"
                android:fontFamily="sans-serif-medium"
                android:textSize="15sp"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/cardMath"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_option_selected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:elevation="0dp"
                    android:layout_marginEnd="8dp">
                    <ImageView 
                        android:id="@+id/ivMathIcon"
                        android:layout_width="32dp" 
                        android:layout_height="32dp" 
                        android:src="@drawable/baseline_calculate_24" 
                        app:tint="#FFFFFF"/>
                    <TextView
                        android:id="@+id/tvMathLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Math Problem"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-black"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardShake"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_option_unselected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp">
                    <ImageView 
                        android:id="@+id/ivShakeIcon"
                        android:layout_width="32dp" 
                        android:layout_height="32dp" 
                        android:src="@drawable/phone_shake" 
                        app:tint="#888888"/>
                    <TextView
                        android:id="@+id/tvShakeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shake Phone"
                        android:textColor="#888888"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Difficulty Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Difficulty"
                android:textColor="#888888"
                android:fontFamily="sans-serif-medium"
                android:textSize="15sp"
                android:layout_marginTop="32dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/cardEasy"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_difficulty_unselected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Easy"
                        android:textColor="#888888"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textColor="#FBC02D" android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardMedium"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_difficulty_selected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium"
                        android:textColor="#FFFFFF"
                        android:fontFamily="sans-serif-black"/>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★★" android:textColor="#FFF" android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardHard"
                    android:layout_width="0dp"
                    android:layout_height="90dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_difficulty_unselected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hard"
                        android:textColor="#888888"
                        android:fontFamily="sans-serif-medium"/>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★★★" android:textColor="#FBC02D" android:textSize="18sp"/>
                </LinearLayout>

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="100dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Save Button Container for shadow effect -->
    <View
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <Button
        android:id="@+id/saveAlarmButton"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="SAVE ALARM"
        android:textSize="18sp"
        android:fontFamily="sans-serif-black"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4364F7"
        app:cornerRadius="30dp"
        android:layout_margin="24dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>