<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <!-- Header -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/primary_color"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_back_button"
        android:src="@drawable/ic_back"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintTop_toTopOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Alarm"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack" />

    <!-- Content Scroll -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        app:layout_constraintBottom_toTopOf="@id/saveAlarmButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Time Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time"
                android:textColor="@color/form_label"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <!-- Time Input -->
            <TextView
                android:id="@+id/tvTimeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="07:00 AM"
                android:textSize="18sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_input_field"
                android:padding="16dp"
                android:layout_marginTop="8dp"/>

            <!-- Repeat Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Repeat"
                android:textColor="@color/form_label"
                android:textSize="14sp"
                android:layout_marginTop="24dp"/>

            <!-- Repeat Days -->
            <LinearLayout
                android:id="@+id/daysContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="7"
                android:layout_marginTop="8dp">

                <TextView android:id="@+id/daySun" style="@style/DayCircle" android:text="S" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
                <TextView android:id="@+id/dayMon" style="@style/DayCircle" android:text="M" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
                <TextView android:id="@+id/dayTue" style="@style/DayCircle" android:text="T" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
                <TextView android:id="@+id/dayWed" style="@style/DayCircle" android:text="W" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
                <TextView android:id="@+id/dayThu" style="@style/DayCircle" android:text="T" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
                <TextView android:id="@+id/dayFri" style="@style/DayCircle" android:text="F" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
                <TextView android:id="@+id/daySat" style="@style/DayCircle" android:text="S" android:layout_weight="1" android:layout_width="0dp" android:gravity="center" android:background="@drawable/bg_day_squircle_unselected" android:textColor="@color/text_on_selector_unselected"/>
            </LinearLayout>

            <!-- Challenge Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Challenge Type"
                android:textColor="@color/form_label"
                android:textSize="14sp"
                android:layout_marginTop="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/cardMath"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_option_selected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="8dp">
                    <!-- Icon Placeholder -->
                    <View android:layout_width="24dp" android:layout_height="24dp" android:background="#FF9800"/> 
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Math Problem"
                        android:textColor="@color/text_on_selector_selected"
                        android:textStyle="bold"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardShake"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_option_unselected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="8dp">
                    <!-- Icon Placeholder -->
                    <View android:layout_width="24dp" android:layout_height="24dp" android:background="#555555"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shake Phone"
                        android:textColor="@color/text_on_selector_unselected"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Difficulty Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Difficulty"
                android:textColor="@color/form_label"
                android:textSize="14sp"
                android:layout_marginTop="24dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:id="@+id/cardEasy"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_difficulty_unselected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Easy"
                        android:textColor="@color/text_on_selector_unselected"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★" android:textColor="#FBC02D"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardMedium"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_difficulty_selected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginHorizontal="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medium"
                        android:textColor="@color/text_on_selector_selected"
                        android:textStyle="bold"/>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★★" android:textColor="#FFF"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardHard"
                    android:layout_width="0dp"
                    android:layout_height="80dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_difficulty_unselected"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hard"
                        android:textColor="@color/text_on_selector_unselected"/>
                     <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="★★★" android:textColor="#FBC02D"/>
                </LinearLayout>

            </LinearLayout>
            
            <!-- Spacer for bottom button -->
            <View android:layout_width="match_parent" android:layout_height="80dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Save Button -->
    <Button
        android:id="@+id/saveAlarmButton"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Save Alarm"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="@color/primary_color"
        app:cornerRadius="24dp"
        android:layout_margin="16dp"
        android:drawableStart="@drawable/ic_check"
        android:drawableTint="#FFFFFF"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>