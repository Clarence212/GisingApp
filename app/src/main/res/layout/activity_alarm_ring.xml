<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF5722"
    tools:context=".AlarmRingActivity">

    <TextView
        android:id="@+id/tvRingTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WAKE UP!"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@+id/tvRingTime"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvRingTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="07:00"
        android:textSize="64sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@+id/tvChallengePrompt"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvRingTitle" />

    <TextView
        android:id="@+id/tvChallengePrompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Solve the challenge to stop!"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:layout_marginTop="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvRingTime" />

    <Button
        android:id="@+id/btnSolveChallenge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Solve Challenge"
        android:textSize="20sp"
        android:textColor="#FF5722"
        android:backgroundTint="#FFFFFF"
        android:paddingHorizontal="32dp"
        android:paddingVertical="16dp"
        app:cornerRadius="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvChallengePrompt" />

</androidx.constraintlayout.widget.ConstraintLayout>